  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::AudioTest
  firstClip: {fileID: 8300000, guid: 81e2056ba62b1eb44b991f5d88e084d0, type: 3}
  secondClip: {fileID: 8300000, guid: f9d39f93ee61a3f4a9ef8eb75510c0a0, type: 3}
  firstSubtitles:
  - text: "\u041F\u0440\u0438\u0432\u0435\u0442"
    delay: 0
  secondSubtitles:
  - text: "\u041E, \u0432\u043E\u0442 \u044D\u0442\u043E \u0441\u044E\u0440\u043F\u0438\u0437"
    delay: 0
  - text: "\u041C\u0430\u0440\u0441\u043E\u0445\u043E\u0434 \"\u041D\u0430\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u044C\""
    delay: 2
  - text: "\u0427\u0435\u0441\u0442\u043D\u043E \u0433\u043E\u0432\u043E\u0440\u044F,
      \u043D\u0435 \u043E\u0436\u0438\u0434\u0430\u043B \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u0442\u044C
      \u043A\u043E\u0433\u043E-\u0442\u043E \u0438\u0437 \u0441\u0442\u0430\u0440\u044B\u0445
      \u0437\u043D\u0430\u043A\u043E\u043C\u044B\u0445"
    delay: 4.5
  - text: "\u041E\u043D \u0442\u0443\u0442 \u0441 2021, \u043E\u0434\u0438\u043D,
      \u0432 \u044D\u0442\u043E\u0439 \u043F\u044B\u043B\u0438"
    delay: 8
  - text: "\u0438 \u0432\u0441\u0435 \u0435\u0449\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442!"
    delay: 12
